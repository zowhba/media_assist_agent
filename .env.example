# Copy this file to `.env` and fill in actual values. Never commit `.env`.

# Jira Personal Access Token (Server/DC) — for REST API auth
JIRA_ACCESS_TOKEN=your-jira-pat-here

# Anthropic API key — for Claude analysis
CLAUDE_API_KEY=sk-ant-api03-...

# PostgreSQL connection string (users / settings groups are stored here)
# Neon example: postgresql://user:pass@host/db?sslmode=require&channel_binding=require
APP_DB_URL=postgresql://user:pass@host/dbname?sslmode=require

# (optional) Confluence PAT — currently unused but reserved
CONFLUENCE_ACCESS_TOKEN=
